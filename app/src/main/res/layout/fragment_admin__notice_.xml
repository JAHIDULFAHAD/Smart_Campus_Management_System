<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Fragment Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Admin Notice"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp"/>

        <!-- Notice Type Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="12dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Notice Type"
                android:textSize="16sp"
                android:textColor="#616161"
                android:layout_marginBottom="4dp"/>

            <Spinner
                android:id="@+id/spinnerNoticeType"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/edit_text_profile_shape"
                android:padding="8dp"/>
        </LinearLayout>

        <!-- Notice Title Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="12dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Notice Title"
                android:textSize="16sp"
                android:textColor="#616161"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/etNoticeTitle"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/edit_text_profile_shape"
                android:padding="12dp"
                android:hint="Enter title here"
                android:textSize="16sp"/>
        </LinearLayout>

        <!-- Notice Description Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="12dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Notice Description"
                android:textSize="16sp"
                android:textColor="#616161"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/etNoticeDescription"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:background="@drawable/edit_text_profile_shape"
                android:padding="12dp"
                android:gravity="top"
                android:hint="Enter description here"
                android:inputType="textMultiLine"
                android:textSize="16sp"/>
        </LinearLayout>

        <!-- Upload Button -->
        <Button
            android:id="@+id/btnUploadNotice"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Upload Notice"
            android:backgroundTint="#1976D2"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="16dp"/>
    </LinearLayout>

</ScrollView>
