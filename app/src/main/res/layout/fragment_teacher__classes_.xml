<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <!-- Today Classes -->
    <TextView
        android:id="@+id/tvTodayLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Today's Classes"
        android:textSize="18sp"
        android:textStyle="bold"
        android:paddingBottom="8dp"/>

    <TextView
        android:id="@+id/tvNoToday"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No classes today"
        android:visibility="gone"
        android:textColor="@android:color/darker_gray"
        android:paddingBottom="8dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvTodayClasses"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:nestedScrollingEnabled="false"/>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@android:color/darker_gray"
        android:layout_marginVertical="16dp"/>

    <!-- Weekly Classes -->
    <TextView
        android:id="@+id/tvWeeklyLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Weekly Classes"
        android:textSize="18sp"
        android:textStyle="bold"
        android:paddingBottom="8dp"/>

    <TextView
        android:id="@+id/tvNoWeekly"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No weekly classes"
        android:visibility="gone"
        android:textColor="@android:color/darker_gray"
        android:paddingBottom="8dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvWeeklyClasses"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:nestedScrollingEnabled="false"/>

</LinearLayout>
