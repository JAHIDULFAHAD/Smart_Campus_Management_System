<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F9FAFB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Quick Actions Grid -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quick Actions"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="2"
            android:alignmentMode="alignMargins"
            android:rowOrderPreserved="false"
            android:layout_marginBottom="24dp"
            android:gravity="center">

            <!-- Upload Result Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_margin="8dp"
                android:layout_columnWeight="1"
                app:cardCornerRadius="18dp"
                app:cardElevation="5dp"
                android:foreground="?attr/selectableItemBackground"
                android:backgroundTint="#E3F2FD">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/btnUploadResult"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Upload Result"
                        android:textColor="#0D47A1"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- View Students Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_margin="8dp"
                android:layout_columnWeight="1"
                app:cardCornerRadius="18dp"
                app:cardElevation="5dp"
                android:foreground="?attr/selectableItemBackground"
                android:backgroundTint="#E8F5E9">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/btnViewStudents"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View Students"
                        android:textColor="#1B5E20"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- View Schedule Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_margin="8dp"
                android:layout_columnWeight="1"
                app:cardCornerRadius="18dp"
                app:cardElevation="5dp"
                android:foreground="?attr/selectableItemBackground"
                android:backgroundTint="#FFF3E0">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/btnViewSchedule"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View Schedule"
                        android:textColor="#E65100"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- View Notices Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_margin="8dp"
                android:layout_columnWeight="1"
                app:cardCornerRadius="18dp"
                app:cardElevation="5dp"
                android:foreground="?attr/selectableItemBackground"
                android:backgroundTint="#F3E5F5">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/btnViewNotices"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View Notices"
                        android:textColor="#4A148C"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </GridLayout>

        <!-- Today's Classes Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="8dp"
            android:layout_marginBottom="8dp">

            <View
                android:layout_width="6dp"
                android:layout_height="28dp"
                android:background="@color/teal_700"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/tvTodayClassesTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today's Classes"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <!-- Horizontal RecyclerView for Today’s Classes -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerTodayClasses"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false"
            android:paddingBottom="16dp"
            android:layout_marginBottom="24dp"
            android:orientation="horizontal" />

        <!-- Recent Notices Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="8dp"
            android:layout_marginBottom="8dp">

            <View
                android:layout_width="6dp"
                android:layout_height="28dp"
                android:background="@color/teal_700"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/tvTeacherNoticesTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recent Notices"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <!-- Vertical RecyclerView for Notices -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerTeacherNotices"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:clipToPadding="false"
            android:paddingBottom="16dp"
            android:layout_marginBottom="16dp"
            android:nestedScrollingEnabled="false" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
